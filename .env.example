# ============================================
# INTELLIDOC AI - ENVIRONMENT VARIABLES
# ============================================

# ============================================
# NODE.JS BACKEND
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/intellidoc?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb://localhost:27017/intellidoc_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3 (Alternative)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=intellidoc-documents

# ============================================
# PYTHON AI SERVICE
# ============================================
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0

# Gemini API
GEMINI_API_KEY=AIzaSyDHier3XHpkXQkWr1__fSHAWPgIyjY6MZw

# OpenAI (Optional)
OPENAI_API_KEY=your-openai-api-key

# Model Paths
LAYOUTLM_MODEL_PATH=./ml_models/layoutlmv3
DONUT_MODEL_PATH=./ml_models/donut
FAISS_INDEX_PATH=./ml_models/faiss_index

# OCR Settings
OCR_ENGINE=paddleocr
OCR_LANGUAGE=en
TESSERACT_PATH=/usr/bin/tesseract

# Processing
MAX_WORKERS=4
BATCH_SIZE=8
CONFIDENCE_THRESHOLD=0.7

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://localhost:5000/api/v1
VITE_AI_SERVICE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:5000
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# ============================================
# DOCKER
# ============================================
COMPOSE_PROJECT_NAME=intellidoc-ai

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# EMAIL (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@intellidoc.ai
